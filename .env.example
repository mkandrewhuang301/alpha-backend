# Alpha Backend — Environment Variables
# Copy this file to .env and fill in real values.

# Development / Production mode
# Set to true for local dev — restricts ingestion to 3 series, debounces WS, disables arq crons.
# Set to false for production — global firehose, arq crons enabled.
DEV_MODE=true

# Kalshi API credentials (RSA key pair)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# Kalshi API endpoints
KALSHI_BASE_API_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Database (PostgreSQL via Supabase — use the pooler URL for lower latency)
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Redis (Railway)
# Local dev: use the public Railway proxy URL
REDIS_URL=redis://default:[password]@caboose.proxy.rlwy.net:[port]
# On Railway itself: set REDIS_URL to the internal URL in Railway dashboard env vars:
# REDIS_URL=redis://default:[password]@redis.railway.internal:6379

# App environment
ENVIRONMENT=development

# Magic Link — secret key for verifying DID tokens from the iOS app
MAGIC_SECRET_KEY=

# Polygon RPC — node provider URL for on-chain interactions (Alchemy or Infura)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Polymarket — CLOB API credentials (reading markets + submitting orders)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polymarket — relayer credentials (Safe deployment + gasless transactions)
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
POLYMARKET_RELAYER_KEY=
POLYMARKET_RELAYER_ADDRESS=

# Polymarket — builder credentials for order attribution and fee sharing (builder program)
POLYMARKET_BUILDER_KEY=
POLYMARKET_BUILDER_ADDRESS=

# Polymarket — CLOB API host
CLOB_HOST=https://clob.polymarket.com

# Encryption key for user CLOB credentials stored in DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Future integrations (not yet required)
# CLAUDE_API_KEY=
# SPORTRADAR_API_KEY=
# ROTOWIRE_API_KEY=
# OPENWEATHER_API_KEY=
# FIREBASE_CREDENTIALS_PATH=
