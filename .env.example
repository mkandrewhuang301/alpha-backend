# Alpha Backend — Environment Variables
# Copy this file to .env and fill in real values.

# Development / Production mode
# Set to true for local dev — restricts ingestion to 3 series, debounces WS, disables arq crons.
# Set to false for production — global firehose, arq crons enabled.
DEV_MODE=true

# Kalshi API credentials (RSA key pair)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# Kalshi API endpoints
KALSHI_BASE_API_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Database (PostgreSQL via Supabase — use the pooler URL for lower latency)
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Redis (Railway)
# Local dev: use the public Railway proxy URL
REDIS_URL=redis://default:[password]@caboose.proxy.rlwy.net:[port]
# On Railway itself: set REDIS_URL to the internal URL in Railway dashboard env vars:
# REDIS_URL=redis://default:[password]@redis.railway.internal:6379

# App environment
ENVIRONMENT=development

# Supabase (required for Auth JWT verification and user management)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Optional: only needed for older Supabase projects using HS256 JWTs
# SUPABASE_JWT_SECRET=

# Intelligence engine
OPENAI_API_KEY=
NEWSAPI_KEY=
SPORTRADAR_API_KEY=
SPORTRADAR_TIER=trial
FIREBASE_CREDENTIALS_JSON=
FCM_ENABLED=true
INTELLIGENCE_ENABLED=true

# Future integrations (not yet required)
# ROTOWIRE_API_KEY=
# OPENWEATHER_API_KEY=
# POLYMARKET_API_KEY=
